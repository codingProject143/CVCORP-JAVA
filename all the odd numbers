import java.util.Scanner;
class main {
    public static void main(String[] args){
        Scanner Sc = new Scanner(System.in);
        int a=Sc.nextInt();
        int b=Sc.nextInt();
        if(a>b || b<a)
        {
            System.out.print("INVALID RANGE");
        }
        else
        {
            for(int i=a;i<=b;i++)
            {
                if(i%2==1)
                {
                    System.out.print(i+" ");
                }
            }
        }
    }
}
