import java.util.Scanner;
class main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n1 = sc.nextInt();
        int n2 = sc.nextInt();
        if(n1>n2)
        {
            System.out.print("INVALID RANGE");
            return;
        }
        int sum =0;
        for(int i=n1;i<=n2;i++)
        {
            sum=sum+i;
        }
        System.out.print(sum+" ");
    }
}
